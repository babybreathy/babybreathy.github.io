        // 渲染菜谱函数
        function renderRecipes(recipesToRender) {
            const grid = document.getElementById('recipesGrid');
            const countEl = document.getElementById('recipeCount');

            if (!grid || !countEl) return;

            countEl.textContent = recipesToRender.length;

            if (recipesToRender.length === 0) {
                grid.innerHTML = '<p style="text-align: center; color: var(--text-secondary); grid-column: 1/-1;">没有找到匹配的菜谱</p>';
                return;
            }

            grid.innerHTML = recipesToRender.map(recipe => `
                <div class="recipe-card" onclick="showRecipe(${recipe.id})">
                    <div class="recipe-image">
                        ${recipe.emoji}
                        <span class="recipe-tag">${getCategoryName(recipe.category)}</span>
                    </div>
                    <div class="recipe-content">
                        <h3 class="recipe-title">${recipe.name}</h3>
                        <div class="recipe-meta">
                            <span>⏱️ ${recipe.time}</span>
                            <span>📊 ${recipe.difficulty}</span>
                            <span>🔥 ${recipe.calories}卡</span>
                        </div>
                        <div class="recipe-ingredients">
                            ${recipe.mainIngredients.slice(0, 3).map(ing => `<span class="ingredient-tag">${ing}</span>`).join('')}
                        </div>
                    </div>
                </div>
            `).join('');
        }

        // 获取分类名称
        function getCategoryName(category) {
            const names = {
                'egg': '蛋类',
                'chicken': '禽肉',
                'beef': '牛肉',
                'pork': '猪肉',
                'seafood': '海鲜',
                'vegetable': '素菜',
                'soup': '汤品',
                'staple': '主食',
                'cold': '凉菜'
            };
            return names[category] || category;
        }

        // 搜索菜谱 - 支持多食材搜索
        function searchRecipes() {
            const input = document.getElementById('searchInput');
            if (!input) return;

            const searchTerm = input.value.trim();

            if (!searchTerm) {
                renderRecipes(recipes);
                return;
            }

            // 支持多种分隔符：空格、逗号、顿号、分号
            const keywords = searchTerm.split(/[\s,,.;,]/).filter(k => k.trim().length > 0);

            if (keywords.length === 0) {
                renderRecipes(recipes);
                return;
            }

            // 多食材搜索：匹配所有关键词
            const filtered = recipes.filter(recipe => {
                const searchText = (
                    recipe.name + ' ' +
                    recipe.mainIngredients.join(' ') + ' ' +
                    recipe.ingredients.map(ing => ing.name).join(' ')
                ).toLowerCase();

                // 所有关键词都要匹配到
                return keywords.every(keyword =>
                    searchText.includes(keyword.toLowerCase().trim())
                );
            });

            renderRecipes(filtered);
        }

        // 搜索框回车事件
        function initSearch() {
            const searchInput = document.getElementById('searchInput');
            if (searchInput) {
                searchInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        searchRecipes();
                    }
                });
            }
        }

        // 显示菜谱详情
        function showRecipe(id) {
            const recipe = recipes.find(r => r.id === id);
            if (!recipe) return;

            document.getElementById('modalEmoji').textContent = recipe.emoji;
            document.getElementById('modalTitle').textContent = recipe.name;
            document.getElementById('modalMeta').innerHTML = `
                <div class="modal-meta-item">⏱️ ${recipe.time}</div>
                <div class="modal-meta-item">📊 ${recipe.difficulty}</div>
                <div class="modal-meta-item">🔥 ${recipe.calories}卡</div>
            `;

            const ingredientsHtml = recipe.ingredients.map(ing => `
                <div class="ingredient-item">
                    <span class="ingredient-name">${ing.name}</span>
                    <span class="ingredient-amount">${ing.amount}</span>
                </div>
            `).join('');

            const stepsHtml = recipe.steps.map((step, index) => `
                <div class="step-item">
                    <div class="step-number">${index + 1}</div>
                    <div class="step-content">${step}</div>
                </div>
            `).join('');

            document.getElementById('modalBody').innerHTML = `
                <div class="modal-section">
                    <h3 class="modal-section-title">📝 食材清单</h3>
                    <div class="ingredients-list">${ingredientsHtml}</div>
                </div>
                <div class="modal-section">
